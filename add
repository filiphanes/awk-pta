#!/bin/sh
# Creates a transaction interactively.
# Uses fzf for fuzzy-selecting accounts from existing postings.
#
# Usage: pta add

DIR="$(cd "$(dirname "$0")" && pwd)"
DATE=$(date +%Y-%m-%d)

printf "Date [%s]: " "$DATE" >&2
read d
[ -z "$d" ] || DATE=$d

printf "Description: " >&2
read DESC

printf "Amount: " >&2
read AMOUNT

A1=$(cat "$DIR"/*.txt 2>/dev/null | "$DIR/postings" | "$DIR/accounts" | sort -u | fzf --prompt="Account 1: " || true)
A2=$(cat "$DIR"/*.txt 2>/dev/null | "$DIR/postings" | "$DIR/accounts" | sort -u | fzf --prompt="Account 2: " || true)

echo ""
echo "$DATE $DESC"
echo "  $AMOUNT $A1"
echo " $((0 - AMOUNT)) $A2"
